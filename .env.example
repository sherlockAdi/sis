# =========================
# SIS EHRM - Example .env
# =========================
# IMPORTANT:
# - Do NOT commit your real .env to git.
# - Replace placeholders (***CHANGE_ME***) with your real secrets.
# - Rotate any secrets that were ever shared in chat.

NODE_ENV=development
PORT=3000

# ---- MySQL ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=***CHANGE_ME***
DB_NAME=sis_global

# ---- JWT ----
JWT_SECRET=***CHANGE_ME***
JWT_EXPIRES_IN=1d
ALLOW_BOOTSTRAP=false

# ---- MinIO (S3-compatible) ----
# You can keep endpoint as "host:port"
MINIO_ENDPOINT=66.116.225.237:9000
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=sis
MINIO_ACCESS_KEY=***CHANGE_ME***
MINIO_SECRET_KEY=***CHANGE_ME***
# MINIO_REGION=us-east-1

# ---- SMTP (Gmail example) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=adityaitesco@gmail.com
SMTP_PASS=***CHANGE_ME***
SMTP_FROM=adityaitesco@gmail.com

