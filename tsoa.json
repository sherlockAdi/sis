{
  "entryFile": "src/server.ts",
  "controllerPathGlobs": ["src/controllers/**/*Controller.ts"],
  "noImplicitAdditionalProperties": "throw-on-extras",
  "spec": {
    "outputDirectory": "build",
    "specVersion": 3,
    "securityDefinitions": {
      "jwt": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "routes": {
    "routesDir": "src",
    "authenticationModule": "src/middleware/auth.ts",
    "middleware": "express"
  }
}
