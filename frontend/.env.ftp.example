## FTP deploy config (used by `npm run deploy:ftp`)
# Copy to `.env.ftp` and fill values. Keep `.env.ftp` private.

# ftp.example.com
FTP_HOST=

# 21 (optional)
FTP_PORT=

# ftp | ftps
FTP_PROTOCOL=ftp

FTP_USER=
FTP_PASS=

# Example: /public_html/sis
FTP_REMOTE_DIR=

# Upload concurrency
FTP_PARALLEL=4

# 1 = delete remote files that no longer exist locally
FTP_DELETE=1

# 1 = skip TLS cert verification (FTPS only; avoid if possible)
FTP_INSECURE_TLS=0
